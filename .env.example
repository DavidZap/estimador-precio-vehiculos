APP_NAME=vehicle-price-estimator
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:[YOUR_PASSWORD]@[YOUR_SUPABASE_HOST]:5432/postgres
DATABASE_SSL_MODE=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false
MERCADOLIBRE_SITE_ID=MCO
MERCADOLIBRE_API_BASE_URL=https://api.mercadolibre.com
MERCADOLIBRE_WEB_BASE_URL=https://listado.mercadolibre.com.co
MERCADOLIBRE_TIMEOUT_SECONDS=30
MERCADOLIBRE_DEFAULT_LIMIT=20
MERCADOLIBRE_ENABLE_BROWSER_FALLBACK=true
MERCADOLIBRE_BROWSER_HEADLESS=true
MERCADOLIBRE_BROWSER_WAIT_MS=8000
COLOMBIA_GEO_SOURCE_URL=https://www.datos.gov.co/api/views/gdxc-w37w/rows.json?accessType=DOWNLOAD
RAW_STORAGE_PATH=./data/raw
ARTIFACTS_PATH=./data/artifacts
LOG_LEVEL=INFO
STREAMLIT_API_BASE_URL=http://localhost:8000/api/v1
